# 投稿を許可するXアカウントのhandle。ログイン中アカウントがこれと違う場合は停止する。
X_BROWSER_POST_ACCOUNT_HANDLE=nazomatic

# 候補にするRealtimeイベントのhashtag。
X_BROWSER_POST_HASHTAG=#謎チケ売ります

# Playwright storage stateの保存先。user data dir方式なら空でよい。
X_BROWSER_POST_STORAGE_STATE=

# ログイン状態を保存するChrome専用プロファイル。Cookie等を含むためGit管理しない。
X_BROWSER_POST_USER_DATA_DIR=local/x-browser-posting/chrome-profile

# trueなら投稿ボタン押下前にCLIで人間確認を求める。
X_BROWSER_POST_REQUIRE_CONFIRMATION=true

# 互換用。trueかつREQUIRE_CONFIRMATION=falseのときだけ確認なし投稿を許可する。
X_BROWSER_POST_ALLOW_UNATTENDED=false

# 投稿前確認モード。通常はinteractive。autoはAUTO_EXECUTE_ALLOWED=trueも必要。
X_BROWSER_POST_CONFIRMATION_MODE=interactive

# trueならCONFIRMATION_MODE=autoによる確認なし投稿を許可する二重ロック。
X_BROWSER_POST_AUTO_EXECUTE_ALLOWED=false

# 空なら静的テンプレート50件からランダム選択する。固定文面にしたい場合だけ指定する。
X_BROWSER_POST_COMMENT=

# 週末サマリ投稿の一言。空ならローカル候補文を使う。CLIの--lineでも指定できる。
X_BROWSER_POST_WEEKEND_SUMMARY_LINE=

# 週末サマリ投稿の文案パターン固定用。空ならランダム。
# ai_self_deprecation / ticket_transfer_aruaru / event_title_commentary
X_BROWSER_POST_WEEKEND_SUMMARY_COPY_PATTERN=

# trueなら土日合計0件でも週末サマリを投稿候補にする。
X_BROWSER_POST_WEEKEND_SUMMARY_POST_WHEN_ZERO=false

# 謎解き界隈トレンドのネタ投稿。空なら検索結果からローカル候補文を使う。CLIの--lineでも指定できる。
X_BROWSER_POST_TREND_JOKE_LINE=

# トレンドネタ投稿の文案生成provider。fallback / codex / command。
# Codex自動運用では codex を指定し、生成に失敗した場合はローカルfallbackへ戻る。
X_BROWSER_POST_TREND_JOKE_COPY_PROVIDER=fallback

# codex providerで使うモデル。空ならCodex CLIの既定モデル。
X_BROWSER_POST_TREND_JOKE_CODEX_MODEL=

# command provider用。JSONをstdinで受け取り、{"text":"...","shape":"..."} または本文だけをstdoutへ返す。
X_BROWSER_POST_TREND_JOKE_PROVIDER_COMMAND=

# 文案生成providerのタイムアウトと試行回数。
X_BROWSER_POST_TREND_JOKE_PROVIDER_TIMEOUT_MS=120000
X_BROWSER_POST_TREND_JOKE_PROVIDER_ATTEMPTS=2

# provider生成文をCONFIRMATION_MODE=autoで実投稿するための追加ロック。
# 初期監視中はfalseのままにし、品質確認後だけtrueにする。
X_BROWSER_POST_TREND_JOKE_PROVIDER_AUTO_APPROVE=false

# ネタ投稿のtopic固定用。空なら検索結果からランダム。
# event_title_vibes / event_title_aruaru / title_makes_me_want_to_go / ticket_transfer_title_window / companion_search_title_hook / weekend_title_overflow / quiet_day
X_BROWSER_POST_TREND_JOKE_TOPIC=

# ネタ投稿の検索query bundle固定用。空ならランダム。
# event_title_general / ticket_title_window / companion_title_window / title_aruaru_words / weekend_title_window
X_BROWSER_POST_TREND_JOKE_QUERY_BUNDLE=

# カンマ区切りで検索queryを直接指定する。空ならquery bundleを使う。
X_BROWSER_POST_TREND_JOKE_SEARCH_QUERIES=

# 1回のprepareで実行する検索query数の上限。
X_BROWSER_POST_TREND_JOKE_MAX_SEARCH_QUERIES=3

# 1 queryあたりに取得するpost数の上限。
X_BROWSER_POST_TREND_JOKE_MAX_POSTS_PER_QUERY=20

# 1日複数回実行時の実行枠。空ならCLIがローカルstateからslot-1, slot-2...を自動採番する。
X_BROWSER_POST_TREND_JOKE_RUN_SLOT=

# 各オートメーションの実行ログを残す世代数。未設定や不正値なら10。
X_BROWSER_POST_LOG_RETENTION_COUNT=10

# 1回の実行で投稿できる最大件数。安全上、現在は1のみ許可。
X_BROWSER_POST_MAX_PER_RUN=1

# 同じアカウントで次に投稿できるまでの待機時間（分）。
X_BROWSER_POST_COOLDOWN_MINUTES=3

# 同じアカウントで1日に投稿できる最大件数。
X_BROWSER_POST_DAILY_LIMIT=30

# 内部APIを呼ぶNext.jsアプリのbase URL。
X_BROWSER_POST_API_BASE_URL=https://nazomatic.vercel.app

# 内部API用Bearer token。空ならREALTIME_INTERNAL_API_TOKEN等を参照する。
X_BROWSER_POST_INTERNAL_TOKEN=

# Playwrightで使うChromium channel。chromeなら通常のGoogle Chromeを使う。
X_BROWSER_POST_BROWSER_CHANNEL=chrome

# 通常Chromeの実行ファイル。login-onlyではPlaywrightを使わずこれを直接起動する。
X_BROWSER_POST_CHROME_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# 通常Chromeへ接続するためのDevTools URL。login-onlyで同じportを開く。
X_BROWSER_POST_CDP_URL=http://127.0.0.1:9222

# login-onlyで通常Chromeを起動するときのremote debugging port。
X_BROWSER_POST_REMOTE_DEBUGGING_PORT=9222

# trueならCDP接続できないときに通常Chromeを自動起動する。
X_BROWSER_POST_AUTO_START_CHROME=true

# Chrome自動起動後にCDP接続を待つ最大時間（ミリ秒）。
X_BROWSER_POST_CHROME_STARTUP_TIMEOUT_MS=20000

# trueなら実行開始時に古いX投稿作成タブを閉じて入力先のズレを防ぐ。
X_BROWSER_POST_CLEANUP_COMPOSE_TABS=true

# falseなら実行中にChromeを前面に出さない（focus emulationで背景のまま入力する）。
X_BROWSER_POST_BRING_TO_FRONT=true

# trueならChrome自動起動をheadless（--headless=new）にして画面を一切出さない。
# UAにHeadlessChromeが含まれるため、X側の挙動が変わる可能性がある点に注意。
# login-onlyには適用されない（手動ログインのため常に画面あり）。
X_BROWSER_POST_HEADLESS=false

# trueなら実行後にブラウザを閉じずに残す。確認やデバッグ用。
X_BROWSER_POST_KEEP_OPEN=false
